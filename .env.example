GREENNODE_CLIENT_ID=
GREENNODE_CLIENT_SECRET=
GREENNODE_AGENT_IDENTITY=

# LLM provider (any OpenAI-compatible)
# GreenNode AIP: LLM_BASE_URL=https://maas-llm-aiplatform-hcm.api.vngcloud.vn/v1
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=

# Memory (created by /agentbase-memory)
MEMORY_ID=
MEMORY_STRATEGY_ID=default

# Jira (https://jira.zalopay.vn)
JIRA_BASE_URL=https://jira.zalopay.vn
JIRA_USERNAME=thucnt2@vng.com.vn
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=          # optional: filter by project key, e.g. PROJ
JIRA_STATUS_FILTER=        # optional: e.g. "In Progress,To Do"
ACTIVE_JIRA_TASKS=In Progress,To Do   # statuses considered "active"
ACTIVE_JIRA_TASKS=(project in ("PCF-Bank Solutions", "Enterprise Architect") AND ("Team Involve" in ("PCF-Partner Integration", PCF-Phoenix) OR filter = bank_assignee) OR project = "ZaloPay Production Issue" AND filter = bank_CRT_issue AND status not in (Resolved, CLOSED)) AND assignee = thucnt2 AND status not in (DONE,"Blocked / On hold") and Sprint in openSprints() ORDER BY priority, Created DESC

# Confluence (https://confluence.zalopay.vn)
CONFLUENCE_BASE_URL=https://confluence.zalopay.vn
CONFLUENCE_SPACE_KEY=      # optional: default space key, e.g. TEAM
CONFLUENCE_USERNAME=       # optional: defaults to JIRA_USERNAME
CONFLUENCE_API_TOKEN=      # optional: defaults to JIRA_API_TOKEN

# Notion
NOTION_API_TOKEN=
NOTION_DATABASE_ID=        # optional: default todos database ID

# Power Automate (optional)
POWER_AUTOMATE_WEBHOOK_URL=

# Web UI
UI_USER_ID=thucnt2
